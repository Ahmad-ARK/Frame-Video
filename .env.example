# ============================================================
#  documentary-pipeline — environment configuration
#  Copy this file to .env and fill in your keys:  cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# LLM KEYS — you need at least one for planning + one for vision
# ------------------------------------------------------------
# Anthropic API key — VISION fallback (used only when GEMINI_API_KEY is unset)
# and the planning fallback. Get one at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek Platform key — PLANNING role (scene direction + title). Cheap
# (~$0.01-0.02/video) and auto-caches. When set, planning uses DeepSeek V4-Flash
# via its Anthropic-compatible endpoint; when unset, planning falls back to
# Anthropic (SCENE_MODEL).
# Get one at: https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-...

# Gemini API key — VISION role (image verify + QA). When set, vision routes to
# Gemini (GEMINI_VISION_MODEL, default the free-tier-friendly Flash-Lite) instead
# of Anthropic Haiku — cheaper and better vision accuracy. When unset, vision
# falls back to Anthropic (VISION_MODEL).
# Get one at: https://aistudio.google.com  → Get API key
# GEMINI_API_KEY=...

# ------------------------------------------------------------
# RECOMMENDED — free keys, big quality boost for b-roll imagery
# (without them the pipeline still works using Wikimedia + Openverse)
# ------------------------------------------------------------
# Free key: https://pixabay.com/api/docs/  (log in → the key is on that page)
PIXABAY_API_KEY=
# Free key: https://www.pexels.com/api/   (sign up → "Your API Key")
PEXELS_API_KEY=

# ------------------------------------------------------------
# OPTIONAL — self-hosted AI image generation (FLUX.1-dev on Modal)
# Used as a last-resort image source when no search result fits.
# Skip this entirely if you don't have a Modal deployment — the
# pipeline degrades gracefully.
# ------------------------------------------------------------
# FLUX_ENDPOINT=https://<your-workspace>--flux-api-model-web.modal.run
# FLUX_MODAL_KEY=
# FLUX_MODAL_SECRET=

# ------------------------------------------------------------
# OPTIONAL — self-hosted neural TTS (Chatterbox on Modal)
# Much better narrator voice than the free fallback.
# Deploy with:   modal deploy modal/chatterbox_tts.py
# Create secret: modal secret create tts-auth TTS_AUTH_TOKEN=<any-random-string>
# Then put the SAME random string here:
# ------------------------------------------------------------
# CHATTERBOX_ENDPOINT=https://<your-workspace>--chatterbox-tts-chatterbox-synthesize.modal.run
# CHATTERBOX_AUTH_TOKEN=
# CHATTERBOX_EXAGGERATION=0.4   # 0 = flat delivery ... 1 = theatrical
# TTS_PROVIDER=auto             # set to "edge" to force the free fallback voice
# TTS_VOICE=en-US-GuyNeural     # voice used by the free Edge fallback

# ------------------------------------------------------------
# OPTIONAL — look & feel
# ------------------------------------------------------------
# Channel-wide visual theme: gold | noir | vintage
# (a "THEME: noir" line inside a topic in input.txt overrides this;
#  when unset, the theme is derived from the script's mood)
# DEFAULT_THEME=gold

# ------------------------------------------------------------
# OPTIONAL — model & length tuning (sensible defaults built in)
# ------------------------------------------------------------
# PLAN_MODEL=deepseek-chat                 # planning model (DeepSeek V4-Flash id; falls back to SCENE_MODEL if no DeepSeek key)
# SCENE_MODEL=claude-sonnet-5              # planning fallback when DEEPSEEK_API_KEY is unset
# GEMINI_VISION_MODEL=gemini-2.5-flash-lite # vision model when GEMINI_API_KEY is set. Switch to "gemini-2.5-flash" for better accuracy once off the free tier.
# VISION_MODEL=claude-haiku-4-5-20251001   # vision fallback when GEMINI_API_KEY is unset
# TARGET_SCRIPT_WORDS=170                  # default video length (~65s); LENGTH: lines override

# ------------------------------------------------------------
# OPTIONAL — render performance (auto-tuned; override only if needed)
# ------------------------------------------------------------
# RENDER_CONCURRENCY=16   # parallel Chrome workers (default: all logical cores). Lower if the machine swaps.
# RENDER_GL=angle         # GPU backend for blur/3D filters. Set "swiftshader" if headless GPU init fails.

# ------------------------------------------------------------
# OPTIONAL — channels (per-channel identity). Select at runtime with
#   npm run run-pipeline -- --channel <name>
# reading channels/<name>.json ({ theme, voice, accent, niche }).
# CHANNEL env var also works instead of the flag.
# ------------------------------------------------------------
# CHANNEL=atlas
